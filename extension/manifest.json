{
  "manifest_version": 3,
  "name": "TabHub",
  "version": "1.1.0",
  "description": "Keep tabs on your tabs. Click the icon to manage your open tabs grouped by domain or window.",
  "permissions": ["tabs", "activeTab", "storage"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "TabHub — Manage your tabs",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
